# ─── App URLs ─────────────────────────────────────────────────────
BASE_URL=http://localhost:8080

# ─── App Startup (optional — omit to skip auto-start) ────────────
# Backend (waterworks) — starts first since FE depends on it
BACKEND_CMD=./dev.sh
BACKEND_CWD=/Users/bryson/src/waterworks
BACKEND_PORT=3000
BACKEND_HEALTH=http://localhost:3000
BACKEND_NAME=waterworks

# Frontend (marvengardens)
FRONTEND_CMD=pnpm dev
FRONTEND_CWD=/Users/bryson/src/marvengardens
FRONTEND_PORT=8080
FRONTEND_HEALTH=http://localhost:8080
FRONTEND_NAME=marvengardens

# ─── Login (optional — omit LOGIN_URL to skip) ───────────────────
LOGIN_URL=http://localhost:8080/login
APP_USERNAME=you@example.com
APP_PASSWORD=yourpassword
USERNAME_SELECTOR=input[name="email"]
PASSWORD_SELECTOR=input[name="password"]
SUBMIT_SELECTOR=button[type="submit"]

# ─── Capture Settings ────────────────────────────────────────────
HEADED=true
SLOW_MO=300
MAX_PAGES=50
PAUSE_MS=2000

# ─── Navigation ──────────────────────────────────────────────────
# CSS selectors for finding links (checked in order, nav links prioritized)
NAV_SELECTORS=nav a[href],aside a[href],[role="navigation"] a[href],a[href]

# Patterns in hrefs to skip
IGNORE_PATTERNS=mailto:,javascript:,logout,sign-out,#
